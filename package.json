{
  "name": "fiscobot-pro",
  "version": "5.0.0",
  "description": "FiscoBot Pro 5.0 — Automacao Fiscal",
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "br.fiscobot.pro",
    "productName": "FiscoBot Pro 5.0",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "preload.js",
      "server.js",
      "public/**/*",
      "assets/**/*",
      "package.json",
      "LICENSE.txt",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FiscoBot Pro",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "language": "1046"
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-ipfilter": "^1.4.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  }
}
